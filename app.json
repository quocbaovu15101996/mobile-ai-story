{
  "expo": {
    "name": "AuraWrite AI",
    "slug": "ai-story-app",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aurawriteai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codezap.ai.story"
    },
    "notification": {
      "icon": "./assets/images/adaptive-icon.png",
      "color": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.codezap.ai.story",
      "permissions": ["com.google.android.gms.permission.AD_ID"],
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "usesCleartextTraffic": true,
            "extraProguardRules": "-keep class com.google.android.gms.internal.consent_sdk.** { *; }"
          }
        }
      ],
      "expo-iap",
      [
        "@react-native-firebase/app",
        {
          "android_package": "com.codezap.ai.story",
          "ios_package": "com.codezap.ai.story"
        }
      ],
      [
        "@react-native-firebase/crashlytics",
        {
          "android_package": "com.codezap.ai.story",
          "ios_package": "com.codezap.ai.story"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49312005-9cf2-4e4e-a83e-334abd69d22f"
      }
    },
    "owner": "quocbao1510"
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-4455918819499290~1099428208",
    "ios_app_id": "ca-app-pub-4455918819499290~1099428208"
  }
}
